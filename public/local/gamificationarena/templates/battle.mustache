<div id="local-ga-battle" data-matchid="{{matchid}}" data-courseid="{{courseid}}">
    <div class="card mb-3">
        <div class="card-body">
            <h4>{{#str}}battle, local_gamificationarena{{/str}}</h4>
            <p id="ga-status">{{queueing}}</p>
            <div class="d-flex justify-content-between">
                <span id="ga-timer"></span>
                <span id="ga-slot"></span>
            </div>
        </div>
    </div>
    <div class="card mb-3">
        <div class="card-body">
            <div id="ga-question">...</div>
            <div class="input-group mt-2">
                <input type="text" class="form-control" id="ga-answer" placeholder="Answer" />
                <div class="input-group-append">
                    <button id="ga-submit" class="btn btn-success">Submit</button>
                </div>
            </div>
        </div>
    </div>
    <div class="card">
        <div class="card-body">
            <h5>{{#str}}leaderboard, local_gamificationarena{{/str}}</h5>
            <ul id="ga-scoreboard" class="list-group"></ul>
            <a href="{{leaderboardurl}}" class="btn btn-link mt-3">View full leaderboard</a>
        </div>
    </div>
</div>
