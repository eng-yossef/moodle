<div id="local-ga-battle" data-matchid="{{matchid}}" data-courseid="{{courseid}}">
    
    <!-- Status Card -->
    <div class="card mb-3">
        <div class="card-body">
            <h4 class="card-title">{{#str}}battle, local_gamificationarena{{/str}}</h4>
            <p id="ga-status" class="card-text font-weight-bold">{{queueing}}</p>
            <div class="d-flex justify-content-between small text-muted">
                <span id="ga-timer"></span>
                <span id="ga-slot"></span>
            </div>
        </div>
    </div>
    
    <!-- Question Card -->
    <div class="card mb-3">
        <div class="card-body">
            <div id="ga-question" class="font-weight-medium mb-2">...</div>
            <div class="input-group">
                <input type="text" 
                       class="form-control" 
                       id="ga-answer" 
                       placeholder="Type your answer..."
                       autocomplete="off"
                       maxlength="200" />
                <div class="input-group-append">
                    <button id="ga-submit" class="btn btn-success">Submit</button>
                </div>
            </div>
            <small class="form-text text-muted">Press Enter to submit</small>
        </div>
    </div>
    
    <!-- Leaderboard Card -->
    <div class="card">
        <div class="card-body">
            <h5 class="card-title">{{#str}}leaderboard, local_gamificationarena{{/str}}</h5>
            <ul id="ga-scoreboard" class="list-group list-group-flush"></ul>
            <a href="{{leaderboardurl}}" class="btn btn-link btn-sm mt-2">View full leaderboard</a>
        </div>
    </div>
    
</div>