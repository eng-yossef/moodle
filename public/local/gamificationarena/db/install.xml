<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/gamificationarena/db" VERSION="2026030500" COMMENT="XMLDB file for local_gamificationarena"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd"
>
  <TABLES>
    <TABLE NAME="local_ga_matches" COMMENT="Challenge matches">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="mode" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="bot"/>
        <FIELD NAME="status" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="queued"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timestarted" TYPE="int" LENGTH="10" NOTNULL="false"/>
        <FIELD NAME="timeended" TYPE="int" LENGTH="10" NOTNULL="false"/>
        <FIELD NAME="winnerid" TYPE="int" LENGTH="10" NOTNULL="false"/>
        <FIELD NAME="difficulty" TYPE="char" LENGTH="10" NOTNULL="true" DEFAULT="medium"/>
        <FIELD NAME="questioncount" TYPE="int" LENGTH="2" NOTNULL="true" DEFAULT="5"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="course_status_idx" UNIQUE="false" FIELDS="courseid,status"/>
      </INDEXES>
    </TABLE>

    <TABLE NAME="local_ga_match_players" COMMENT="Participants in a match">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="matchid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="isbot" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="botdifficulty" TYPE="char" LENGTH="10" NOTNULL="false"/>
        <FIELD NAME="score" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="streak" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="answerscorrect" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="answerstime" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timejoined" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="match_fk" TYPE="foreign" FIELDS="matchid" REFTABLE="local_ga_matches" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="match_user_uix" UNIQUE="true" FIELDS="matchid,userid"/>
      </INDEXES>
    </TABLE>

    <TABLE NAME="local_ga_match_questions" COMMENT="Questions assigned to a match">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="matchid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="questionid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="slot" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="questiontext" TYPE="text" NOTNULL="false"/>
        <FIELD NAME="timelimit" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="30"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="matchquestion_fk" TYPE="foreign" FIELDS="matchid" REFTABLE="local_ga_matches" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="match_slot_uix" UNIQUE="true" FIELDS="matchid,slot"/>
      </INDEXES>
    </TABLE>

    <TABLE NAME="local_ga_answers" COMMENT="Player answers per question">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="matchid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="questionslot" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="answerraw" TYPE="text" NOTNULL="false"/>
        <FIELD NAME="iscorrect" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="responsetime" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="pointsearned" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="ans_match_fk" TYPE="foreign" FIELDS="matchid" REFTABLE="local_ga_matches" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="match_slot_user_uix" UNIQUE="true" FIELDS="matchid,questionslot,userid"/>
      </INDEXES>
    </TABLE>

    <TABLE NAME="local_ga_leaderboard" COMMENT="Aggregated ranking">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="period" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="alltime"/>
        <FIELD NAME="periodkey" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="all"/>
        <FIELD NAME="rankpoints" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="wins" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="losses" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="xp" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="course_user_period_uix" UNIQUE="true" FIELDS="courseid,userid,period,periodkey"/>
      </INDEXES>
    </TABLE>

    <TABLE NAME="local_ga_player_stats" COMMENT="Persistent player stats">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="totmatches" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="wins" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="losses" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="totalxp" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="rating" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="1000"/>
        <FIELD NAME="currentstreak" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="beststreak" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="user_course_uix" UNIQUE="true" FIELDS="userid,courseid"/>
      </INDEXES>
    </TABLE>
  </TABLES>
</XMLDB>
