{{!
    @template local_jobfeed/jobs

    Context variables required for this template:
    * skill string Skill filter currently selected.
    * hasjobs bool Whether jobs list contains data.
    * jobs array Job card rows.
    * haserror bool Whether API call failed.
    * error string Error message.
    * nojobs bool Whether there are no jobs.
    * nojobsmessage string Empty-state message.
    * applylabel string Apply button label.
}}
<div class="local-jobfeed">
    <div class="mb-3">
        <h2>{{#str}}jobopportunities, local_jobfeed{{/str}}</h2>
        <p class="text-muted mb-0">{{#str}}filteredbyskill, local_jobfeed, {{skill}}{{/str}}</p>
    </div>

    {{#haserror}}
        <div class="alert alert-danger" role="alert">{{error}}</div>
    {{/haserror}}

    {{#nojobs}}
        <div class="alert alert-info" role="status">{{nojobsmessage}}</div>
    {{/nojobs}}

    {{#hasjobs}}
        <div class="row">
            {{#jobs}}
                <div class="col-md-6 mb-3">
                    <div class="card h-100">
                        <div class="card-body d-flex flex-column">
                            <h3 class="h5 card-title">{{title}}</h3>
                            <p class="mb-1"><strong>{{#str}}company, local_jobfeed{{/str}}:</strong> {{company}}</p>
                            <p class="mb-1"><strong>{{#str}}location, local_jobfeed{{/str}}:</strong> {{location}}</p>
                            <p class="mb-3 text-muted"><strong>{{#str}}posted, local_jobfeed{{/str}}:</strong> {{date}}</p>
                            <p class="mt-auto mb-0">
                                <a class="btn btn-primary" href="{{url}}" target="_blank" rel="noopener noreferrer">
                                    {{applylabel}}
                                </a>
                            </p>
                        </div>
                    </div>
                </div>
            {{/jobs}}
        </div>
    {{/hasjobs}}
</div>
