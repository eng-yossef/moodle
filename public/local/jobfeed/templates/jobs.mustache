<div class="local-jobfeed-container">
    {{#has_jobs}}
        <div class="local-jobfeed-header mb-4">
            <h2 class="h4 mb-0">{{#str}}jobs_for_skill, local_jobfeed{{/str}}: {{skill}}</h2>
        </div>
        
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-3 local-jobfeed-grid">
            {{#jobs}}
                <div class="col">
                    <div class="card local-job-card h-100 border-0 shadow-sm">
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title text-primary mb-2">
                                <a href="{{url}}" target="_blank" rel="noopener noreferrer" class="text-decoration-none stretched-link">
                                    {{title}}
                                </a>
                            </h5>
                            
                            <h6 class="card-subtitle mb-2 text-muted small">{{company}}</h6>
                            
                            <div class="card-text small text-secondary mb-3 flex-grow-1">
                                <p class="mb-1"><i class="fa fa-map-marker me-1"></i>{{location}}</p>
                                <p class="mb-0"><i class="fa fa-clock-o me-1"></i>{{date}}</p>
                            </div>
                            
                            <div class="mt-auto pt-2">
                                <a href="{{url}}" target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-sm w-100">
                                    {{#str}}apply_now, local_jobfeed{{/str}}
                                    <i class="fa fa-external-link ms-1"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            {{/jobs}}
        </div>
    {{/has_jobs}}
    
    {{^has_jobs}}
        <div class="alert alert-info d-flex align-items-center" role="alert">
            <i class="fa fa-info-circle fa-2x me-3"></i>
            <div>
                <strong>{{#str}}no_jobs_found, local_jobfeed{{/str}}: {{skill}}</strong>
                <p class="mb-0 mt-1 small">{{#str}}try_different_skill, local_jobfeed{{/str}}</p>
            </div>
        </div>
    {{/has_jobs}}
</div>