{{!
  Helpdesk ticket list template.
  @package local_helpdesk
}}
<div class="local-helpdesk-ticketlist container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>{{#str}}mytickets, local_helpdesk{{/str}}</h2>
        <div class="btn-group" role="group" aria-label="Helpdesk actions">
            {{#cancreate}}
            <a href="{{createurl}}" class="btn btn-primary">
                <i class="fa fa-plus"></i> {{#str}}createticket, local_helpdesk{{/str}}
            </a>
            {{/cancreate}}
            <a href="{{chatboturl}}" class="btn btn-outline-primary">
                <i class="fa fa-robot"></i> {{#str}}chatbottitle, local_helpdesk{{/str}}
            </a>
        </div>
        {{^cancreate}}
        <span class="badge badge-warning">{{maxopentickets}}</span>
        {{/cancreate}}
    </div>

    {{#notickets}}
    <div class="alert alert-info">{{#str}}notickets, local_helpdesk{{/str}}</div>
    {{/notickets}}

    {{^notickets}}
    <div class="table-responsive">
        <table class="table table-striped table-hover generaltable">
            <thead>
                <tr>
                    <th>#</th>
                    <th>{{#str}}ticketsubject, local_helpdesk{{/str}}</th>
                    <th>{{#str}}course, local_helpdesk{{/str}}</th>
                    <th>{{#str}}ticketpriority, local_helpdesk{{/str}}</th>
                    <th>{{#str}}status, local_helpdesk{{/str}}</th>
                    <th>{{#str}}createdon, local_helpdesk{{/str}}</th>
                    <th>{{#str}}actions, local_helpdesk{{/str}}</th>
                </tr>
            </thead>
            <tbody>
                {{#tickets}}
                <tr>
                    <td>{{id}}</td>
                    <td>{{subject}}</td>
                    <td>{{coursename}}</td>
                    <td>
                        <span class="badge badge-{{prioritykey}}">{{priority}}</span>
                    </td>
                    <td>
                        <span class="badge helpdesk-status-{{statuskey}}">{{status}}</span>
                    </td>
                    <td>{{timecreated}}</td>
                    <td>
                        <a href="{{viewurl}}" class="btn btn-sm btn-outline-primary">
                            {{#str}}viewticket, local_helpdesk{{/str}}
                        </a>
                    </td>
                </tr>
                {{/tickets}}
            </tbody>
        </table>
    </div>
    {{/notickets}}
</div>

{{! Chat popup placeholder — populated by AMD }}
<div id="helpdesk-chat-popup" class="helpdesk-chat-popup d-none" role="dialog" aria-label="Support Chat"></div>

{{! Unread badge button in bottom-left corner }}
<div id="helpdesk-chat-fab" class="helpdesk-chat-fab d-none" aria-live="polite">
    <button class="btn btn-primary btn-circle" id="helpdesk-chat-fab-btn" title="{{#str}}chat, local_helpdesk{{/str}}">
        <i class="fa fa-comments"></i>
        <span id="helpdesk-unread-badge" class="badge badge-danger helpdesk-unread-badge"></span>
    </button>
</div>

<style>
.helpdesk-chat-fab {
    position: fixed;
    bottom: 20px;
    left: 20px;
    z-index: 1050;
}
.btn-circle {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    padding: 0;
    font-size: 1.4rem;
    position: relative;
}
.helpdesk-unread-badge {
    position: absolute;
    top: -4px;
    right: -4px;
    font-size: 0.7rem;
}
.helpdesk-status-open      { background-color: #17a2b8; color: #fff; }
.helpdesk-status-inprogress{ background-color: #ffc107; color: #212529; }
.helpdesk-status-resolved  { background-color: #28a745; color: #fff; }
.helpdesk-status-closed    { background-color: #6c757d; color: #fff; }
.badge-low    { background-color: #6c757d; color: #fff; }
.badge-medium { background-color: #17a2b8; color: #fff; }
.badge-high   { background-color: #fd7e14; color: #fff; }
.badge-urgent { background-color: #dc3545; color: #fff; }
</style>
